# Copy this file to .env and fill in the values after running `terraform apply`
# Run `terraform output` to get the values below.

export API_URL=""               # from: terraform output api_url
export COGNITO_CLIENT_ID=""     # from: terraform output cognito_client_id
export COGNITO_USER_POOL_ID=""  # from: terraform output cognito_user_pool_id
export AWS_REGION="us-east-1"

# Cognito test user credentials (for integration tests only)
export TEST_EMAIL=""
export TEST_PASSWORD=""
